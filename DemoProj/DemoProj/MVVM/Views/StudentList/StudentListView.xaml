<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DemoProj.MVVM.Views.StudentList.StudentListView"
             xmlns:models="clr-namespace:DemoProj.MVVM.Models.StudentList"
             xmlns:vm="clr-namespace:DemoProj.MVVM.ViewModels.StudentList"
             Title="StudentListView">

    <Grid RowDefinitions="Auto,*,Auto" Padding="15">

        <!-- Table Header -->
        <Border Grid.Row="0" BackgroundColor="#512BD4" Padding="10" StrokeThickness="0" Margin="0,0,0,5">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="5,5,0,0" />
            </Border.StrokeShape>
            <!-- Name | Email | Department | Actions -->
            <Grid ColumnDefinitions="*,2*,*,*">
                <Label Text="Name"       FontAttributes="Bold" TextColor="White" />
                <Label Grid.Column="1"   Text="Email"      FontAttributes="Bold" TextColor="White" />
                <Label Grid.Column="2"   Text="Department" FontAttributes="Bold" TextColor="White" />
                <Label Grid.Column="3"   Text="Action" FontAttributes="Bold" TextColor="White" />
            </Grid>
        </Border>

        <!-- Table Body -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Students}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Student">
                    <Border Stroke="#E0E0E0" StrokeThickness="1" Padding="10" Margin="0,0,0,-1">
                        <Grid ColumnDefinitions="*,2*,*,*" RowDefinitions="Auto">

                            <Label Text="{Binding Name}"
                               VerticalOptions="Center"
                               TextColor="#333333"
                               FontAttributes="Bold" />

                            <Label Grid.Column="1"
                               Text="{Binding Email}"
                               VerticalOptions="Center"
                               TextColor="#666666" />

                            <Label Grid.Column="2"
                               Text="{Binding Department}"
                               VerticalOptions="Center"
                               TextColor="#512BD4" />
                            <Button Text="Edit"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:StudentListViewModel}}, Path=EditCommand}"
                                    CommandParameter="{Binding .}"
                                    Grid.Column="3"
                                    ></Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10" Padding="20">
                    <Label Text="No students found."
                       FontSize="18"
                       HorizontalOptions="Center"
                       TextColor="#999999" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <Button Grid.Row="2"
                Text="Add Student"
                Margin="0,20,0,0"
                Command="{Binding AddStudentCommand}"
                />
    </Grid>
</ContentPage>